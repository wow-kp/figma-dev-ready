#!/bin/sh
# Pre-commit hook: ensure proxy-config values don't leak into version control.
#
# manifest.json is now gitignored (generated at build time from manifest.template.json),
# so we only need to check ui.html for leaked proxy URLs.
#
# Install: git config core.hooksPath .githooks

UI_STAGED=$(git diff --cached --name-only -- ui.html)

if [ -n "$UI_STAGED" ]; then
  # Reset any hardcoded proxy URL to empty string
  if grep -q 'AIClient\.config\.proxyUrl = "http' ui.html 2>/dev/null; then
    sed -i '' 's/AIClient\.config\.proxyUrl = "http[^"]*"/AIClient.config.proxyUrl = ""/' ui.html
    git add ui.html
  fi
fi
